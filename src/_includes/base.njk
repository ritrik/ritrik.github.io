<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <!-- Favicon: SVG (moderní prohlížeče) s .ico jako záloha pro starší -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48 64x64" type="image/vnd.microsoft.icon" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png" />

    <title>{% if title %}{{ title }} · {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}

    <!-- RSS/Atom kanál blogu -->
    <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed.xml" />

    <!--
      Den/noc bez probliknutí: data-bs-theme nastavíme na <html> ještě před vykreslením.
      Uloženou volbu bereme z localStorage, jinak podle systému; výchozí je tmavý režim.
    -->
    <script>
      (function () {
        var saved = localStorage.getItem("theme");
        var theme = saved || (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
        document.documentElement.setAttribute("data-bs-theme", theme);
      })();
    </script>

    <!-- Bootstrap 5.3 (barevné režimy = den/noc) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons (ikony sociálních sítí; názvy ikon viz site.json) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Písma — definovaná v src/_data/site.json (klíč „fonts"), ne natvrdo tady.
         Swap písma = úprava site.json. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?{% for f in site.fonts.google %}family={{ f.spec }}&{% endfor %}display=swap" rel="stylesheet" />
    <style>
      /* Rodiny písem ze site.json → CSS proměnné (jediný zdroj; v site.css se jen používají) */
      :root {
        --serif: {{ site.fonts.serif | safe }};
        --sans: {{ site.fonts.sans | safe }};
        --cascadia: {{ site.fonts.mono | safe }};
      }
    </style>

    <!-- Vlastní styl webu -->
    <link href="/css/site.css" rel="stylesheet" />

    <!-- Téma zvýraznění kódu (vyber v src/_data/site.json → codeTheme; soubory v css/code-themes/) -->
    <link href="/css/code-themes/{{ site.codeTheme or 'vsdark' }}.css" rel="stylesheet" />
  </head>

  <body>
    <!-- ===== Mobilní lišta s burger tlačítkem (jen na úzkých displejích) ===== -->
    <header class="topbar">
      <button id="nav-toggle" type="button" class="burger"
              aria-label="Otevřít / zavřít menu" aria-expanded="false" aria-controls="sidebar">
        <span class="burger-box" aria-hidden="true"><span class="burger-line"></span></span>
      </button>
      <a href="/" class="topbar-brand">
        <picture>
          <source srcset="/img/logo.svg" type="image/svg+xml" />
          <img class="topbar-logo" src="/img/logo.png" alt="" width="28" height="28" eleventy:ignore />
        </picture>
        <span>{{ site.title }}</span>
      </a>
    </header>

    <!-- Ztmavení obsahu pod otevřeným menu (klik = zavřít) -->
    <div class="nav-backdrop"></div>

    <!-- ===== Boční panel (sidebar ve stylu Hyde) ===== -->
    <aside class="sidebar" id="sidebar">
      <!-- Přepínač den/noc: nenápadná ikonka vlevo nahoře -->
      <button id="theme-toggle" type="button" class="theme-toggle"
              aria-label="Přepnout světlý/tmavý režim"
              title="Přepnout světlý/tmavý režim — volba se uloží jen v tomto prohlížeči">
        <span class="theme-ico bi" aria-hidden="true"></span>
      </button>

      <div class="sidebar-top">
        <a href="/" class="sidebar-logo-link" aria-label="Domů">
          <picture>
            <source srcset="/img/logo.svg" type="image/svg+xml" />
            <img class="sidebar-logo" src="/img/logo.png" alt="Logo Ryutaro" width="84" height="84" eleventy:ignore />
          </picture>
        </a>
        <h1 class="sidebar-brand"><a href="/">{{ site.title }}</a></h1>
        <p class="sidebar-tagline">{{ site.tagline }}</p>

        <nav class="sidebar-nav">
          {% for item in site.nav %}
            {% if item.children %}
              {# Rozbalovací skupina (submenu) — pohání Bootstrap Collapse.
                 Otevře se sama, je-li aktivní některá pod-stránka; stav se pamatuje (viz JS). #}
              {% set groupActive = false %}
              {% for c in item.children %}
                {% if (page.url == c.url) or (c.url != "/" and page.url.startsWith(c.url)) %}{% set groupActive = true %}{% endif %}
              {% endfor %}
              {% set collapseId = "nav-collapse-" ~ loop.index %}
              <div class="sidebar-nav-group" data-nav-key="{{ item.text }}">
                <button type="button" class="sidebar-nav-item sidebar-nav-toggle{% if not groupActive %} collapsed{% endif %}{% if groupActive %} active{% endif %}"
                        data-bs-toggle="collapse" data-bs-target="#{{ collapseId }}"
                        aria-controls="{{ collapseId }}" aria-expanded="{{ 'true' if groupActive else 'false' }}">
                  {{ item.text }}<span class="caret" aria-hidden="true"></span>
                </button>
                <div class="sidebar-subnav collapse{% if groupActive %} show{% endif %}" id="{{ collapseId }}">
                  {% for c in item.children %}
                    {% set isActive = (page.url == c.url) or (c.url != "/" and page.url.startsWith(c.url)) %}
                    <a href="{{ c.url }}" class="sidebar-nav-item sidebar-subnav-item{% if isActive %} active{% endif %}"{% if c.newTab %} target="_blank" rel="noopener"{% endif %}>{{ c.text }}{% if c.newTab or (c.url and c.url.startsWith("http")) %}<i class="bi bi-box-arrow-up-right nav-ext" aria-hidden="true"></i>{% endif %}</a>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              {% set isActive = (page.url == item.url) or (item.url != "/" and page.url.startsWith(item.url)) %}
              {# Položka s "icon" se vykreslí jen jako ikona (Bootstrap Icons), jinak jako text. #}
              <a href="{{ item.url }}" class="sidebar-nav-item{% if item.icon %} sidebar-nav-icon{% endif %}{% if isActive %} active{% endif %}"{% if item.newTab %} target="_blank" rel="noopener"{% endif %}{% if item.icon %} aria-label="{{ item.label or item.text }}" title="{{ item.label or item.text }}"{% endif %}>{% if item.icon %}<i class="bi bi-{{ item.icon }}" aria-hidden="true"></i>{% else %}{{ item.text }}{% if item.newTab or (item.url and item.url.startsWith("http")) %}<i class="bi bi-box-arrow-up-right nav-ext" aria-hidden="true"></i>{% endif %}{% endif %}</a>
            {% endif %}
          {% endfor %}
        </nav>
      </div>

      <!-- ===== Patička panelu: sociální sítě + rok + podpis ===== -->
      <footer class="sidebar-footer">
        <div class="social">
          {# Sociální sítě se definují v src/_data/site.json (pole "social").
             Přidání/úprava/zapnutí odkazu = úprava JSONu, ne této šablony.
             "icon" je název ikony z Bootstrap Icons (https://icons.getbootstrap.com).
             Zobrazí se jen položky s "enabled": true. #}
          {% for item in site.social %}
            {% if item.enabled %}
              {% set external = item.url.startsWith("http") %}
              <a class="social-link" href="{{ item.url }}"
                 {% if external %}target="_blank"{% endif %}
                 {% if item.rel %}rel="{{ item.rel }}"{% elif external %}rel="noopener"{% endif %}
                 aria-label="{{ item.label }}" title="{{ item.label }}">
                <i class="bi bi-{{ item.icon }}" aria-hidden="true"></i>
              </a>
            {% endif %}
          {% endfor %}
        </div>

        <p class="sidebar-copy">© <span id="year">2026</span> Ryutaro</p>
        <p class="sidebar-credit">
          Postaveno na <a href="https://www.11ty.dev/" target="_blank" rel="noopener">Eleventy</a>
          &amp; <a href="https://getbootstrap.com/" target="_blank" rel="noopener">Bootstrap</a>.
          Ikony <a href="https://icons.getbootstrap.com/" target="_blank" rel="noopener">Bootstrap&nbsp;Icons</a>,
          zvýraznění kódu <a href="https://prismjs.com/" target="_blank" rel="noopener">Prism</a>,
          vzhled dle tématu <a href="https://github.com/poole/hyde" target="_blank" rel="noopener">Hyde</a>,
          písma {% for f in site.fonts.google %}<a href="https://fonts.google.com/specimen/{{ f.name | replace(' ', '+') }}" target="_blank" rel="noopener">{{ f.name | replace(' ', '&nbsp;') | safe }}</a>{% if loop.revindex0 == 1 %} &amp; {% elif not loop.last %}, {% endif %}{% endfor %}.
        </p>
        <p class="sidebar-credit">Vytvořeno s&nbsp;<a href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude&nbsp;Code</a> · model Claude&nbsp;Opus&nbsp;4.8</p>
      </footer>
    </aside>

    <!-- ===== Obsah ===== -->
    <main class="content{% if cover %} content--cover{% endif %}">
      <div class="content-inner">
        {{ content | safe }}
      </div>
    </main>

    <!-- Bootstrap JS (bundle s Popperem) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Logika přepínače den/noc -->
    <script>
      (function () {
        var root = document.documentElement;

        // Den/noc — ikonka přes Bootstrap Icons (slunce / měsíc)
        var btn = document.getElementById("theme-toggle");
        if (btn) {
          var ico = btn.querySelector(".theme-ico");
          var render = function () {
            // Jen přepnutí třídy ikony (Bootstrap Icons), text se nemění
            var dark = root.getAttribute("data-bs-theme") === "dark";
            ico.className = "theme-ico bi " + (dark ? "bi-sun-fill" : "bi-moon-stars-fill");
          };
          btn.addEventListener("click", function () {
            var next = root.getAttribute("data-bs-theme") === "dark" ? "light" : "dark";
            root.setAttribute("data-bs-theme", next);
            localStorage.setItem("theme", next);
            render();
          });
          render();
        }

        // Aktuální rok v patičce (fallback je napsaný přímo v HTML)
        var y = document.getElementById("year");
        if (y) y.textContent = new Date().getFullYear();

        // Mobilní menu (burger) — vysouvací boční panel na úzkých displejích
        var burger = document.getElementById("nav-toggle");
        var backdrop = document.querySelector(".nav-backdrop");
        var sidebar = document.getElementById("sidebar");

        // Viditelné fokusovatelné prvky uvnitř panelu (sbalené submenu se přeskočí)
        var focusablesInSidebar = function () {
          if (!sidebar) return [];
          var sel = 'a[href], button:not([disabled]), input, select, textarea, [tabindex]:not([tabindex="-1"])';
          return Array.prototype.filter.call(sidebar.querySelectorAll(sel), function (el) {
            return el.offsetParent !== null; // jen skutečně viditelné
          });
        };

        var openNav = function () {
          document.body.classList.add("nav-open");
          if (burger) burger.setAttribute("aria-expanded", "true");
          var f = focusablesInSidebar();
          if (f.length) f[0].focus(); // fokus dovnitř panelu
        };
        var closeNav = function () {
          var wasOpen = document.body.classList.contains("nav-open");
          document.body.classList.remove("nav-open");
          if (burger) {
            burger.setAttribute("aria-expanded", "false");
            if (wasOpen) burger.focus(); // fokus zpět na burger
          }
        };
        if (burger) {
          burger.addEventListener("click", function () {
            if (document.body.classList.contains("nav-open")) closeNav();
            else openNav();
          });
        }
        if (backdrop) backdrop.addEventListener("click", closeNav);
        // Zavřít po kliknutí na odkaz v menu nebo klávesou Esc
        // (jen <a> — ne tlačítko rozbalovací skupiny, to jen otevírá submenu)
        document.querySelectorAll("a.sidebar-nav-item").forEach(function (a) {
          a.addEventListener("click", closeNav);
        });
        document.addEventListener("keydown", function (e) {
          if (!document.body.classList.contains("nav-open")) return;
          if (e.key === "Escape") {
            closeNav();
            return;
          }
          // Zamknutí fokusu v otevřeném menu (Tab cykluje jen uvnitř panelu)
          if (e.key === "Tab") {
            var f = focusablesInSidebar();
            if (!f.length) return;
            var first = f[0];
            var last = f[f.length - 1];
            if (e.shiftKey && document.activeElement === first) {
              e.preventDefault();
              last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
              e.preventDefault();
              first.focus();
            }
          }
        });

        // Tlačítko „Kopírovat" na každém bloku kódu (čísla řádků se nekopírují)
        document.querySelectorAll(".content pre").forEach(function (pre) {
          var code = pre.querySelector("code");
          if (!code) return;
          var copyBtn = document.createElement("button");
          copyBtn.type = "button";
          copyBtn.className = "code-copy";
          copyBtn.innerHTML = '<i class="bi bi-copy" aria-hidden="true"></i>';
          copyBtn.setAttribute("aria-label", "Kopírovat kód");
          copyBtn.setAttribute("title", "Kopírovat kód");
          copyBtn.addEventListener("click", function () {
            var done = function (ok) {
              copyBtn.innerHTML = ok
                ? '<i class="bi bi-check-lg" aria-hidden="true"></i>'
                : '<i class="bi bi-x-lg" aria-hidden="true"></i>';
              copyBtn.classList.toggle("copied", ok);
              setTimeout(function () {
                copyBtn.innerHTML = '<i class="bi bi-copy" aria-hidden="true"></i>';
                copyBtn.classList.remove("copied");
              }, 1500);
            };
            // innerText respektuje zalomení (<br>) a nezahrnuje čísla řádků (::before)
            var text = code.innerText;
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(text).then(function () { done(true); }, function () { done(false); });
            } else {
              done(false);
            }
          });
          pre.appendChild(copyBtn);
        });

        // Submenu pohání Bootstrap Collapse (data-bs-toggle). My jen pamatujeme stav
        // mezi stránkami v localStorage — obnovíme dříve otevřené skupiny a ukládáme
        // přes události Bootstrapu. Skupina s aktivní pod-stránkou je otevřená vždy.
        document.querySelectorAll(".sidebar-nav-group").forEach(function (group) {
          var key = group.getAttribute("data-nav-key");
          var target = group.querySelector(".sidebar-subnav");
          var btn = group.querySelector(".sidebar-nav-toggle");
          if (!target) return;
          // Obnovení: jen otevírá (aktivní skupinu, která už má .show, neřeší)
          if (key && localStorage.getItem("nav-open:" + key) === "1" && !target.classList.contains("show")) {
            target.classList.add("show");
            if (btn) {
              btn.classList.remove("collapsed");
              btn.setAttribute("aria-expanded", "true");
            }
          }
          if (key) {
            target.addEventListener("shown.bs.collapse", function () { localStorage.setItem("nav-open:" + key, "1"); });
            target.addEventListener("hidden.bs.collapse", function () { localStorage.setItem("nav-open:" + key, "0"); });
          }
        });
      })();
    </script>
  </body>
</html>
