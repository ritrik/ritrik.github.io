---
layout: base.njk
permalink: /blog/
title: Blog
description: Články a poznámky.
---
<h1>Blog</h1>
<p class="page-meta">Články &amp; poznámky</p>

{# Filtr podle štítků — funguje na straně prohlížeče (viz skript dole) #}
{% if collections.tagList | length %}
  <nav class="tag-filter" aria-label="Filtrovat články podle štítku">
    <button type="button" class="tag-chip is-active" data-tag="*">Vše</button>
    {% for tag in collections.tagList %}
      <button type="button" class="tag-chip" data-tag="{{ tag }}">{{ tag }}</button>
    {% endfor %}
  </nav>
{% endif %}

{% if collections.posts | length %}
  <ul class="post-list">
    {% for post in collections.posts %}
      <li class="post-item" data-tags="{% for t in post.data.tags %}{% if t != 'posts' %}{{ t }} {% endif %}{% endfor %}">
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a>{% if post.data.draft %} <span class="draft-badge">Koncept</span>{% endif %}</h2>
        <p class="post-meta">{{ post.date | datumCZ }}</p>
        {% if post.data.excerpt %}
          <p class="excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
        {% if post.data.tags | length > 1 %}
          <p class="post-tags">
            {% for t in post.data.tags %}{% if t != 'posts' %}<span class="post-tag">{{ t }}</span>{% endif %}{% endfor %}
          </p>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
  <p class="post-list-empty" hidden>Žádný článek pro tento štítek.</p>
{% else %}
  <p>Zatím tu nejsou žádné články.</p>
{% endif %}

{# Filtrování článků podle štítku — bez přenačtení stránky.
   Respektuje ?tag=… v adrese (na ten odkazují štítky u jednotlivých článků). #}
<script>
  (function () {
    var chips = Array.prototype.slice.call(document.querySelectorAll(".tag-chip"));
    var items = Array.prototype.slice.call(document.querySelectorAll(".post-item"));
    var empty = document.querySelector(".post-list-empty");
    if (!chips.length || !items.length) return;

    function apply(tag, updateUrl) {
      var shown = 0;
      items.forEach(function (li) {
        var tags = (li.getAttribute("data-tags") || "").trim().split(/\s+/);
        var show = tag === "*" || tags.indexOf(tag) !== -1;
        li.hidden = !show;
        if (show) shown++;
      });
      chips.forEach(function (c) {
        c.classList.toggle("is-active", c.getAttribute("data-tag") === tag);
      });
      if (empty) empty.hidden = shown !== 0;
      if (updateUrl) {
        var url = tag === "*" ? location.pathname
                              : location.pathname + "?tag=" + encodeURIComponent(tag);
        history.replaceState(null, "", url);
      }
    }

    chips.forEach(function (c) {
      c.addEventListener("click", function () { apply(c.getAttribute("data-tag"), true); });
    });

    // Počáteční stav podle ?tag= v adrese (jinak „Vše")
    var wanted = new URLSearchParams(location.search).get("tag");
    var known = chips.map(function (c) { return c.getAttribute("data-tag"); });
    apply(wanted && known.indexOf(wanted) !== -1 ? wanted : "*", false);
  })();
</script>
